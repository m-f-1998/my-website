{
  "name": "my-website-server",
  "version": "1.0.0",
  "description": "Server for my Website",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "prestart": "npm i",
    "start": "node --env-file=.env --watch ./ index.js",
    "dev": "npm run prestart && npx --yes nodemon -e ts --exec \"tsc && node ./dist/index.js\"",
    "lint": "npx --yes eslint",
    "lint:fix": "npx --yes eslint --fix",
    "tsc-verify": "npx --yes tsc --noEmit"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "nodemailer": "^8.0.10",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.16.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "volta": {
    "node": "24.15.0"
  }
}
